# ── Desenvolvimento local (Fastify) ────────────────────────────────────────
VITE_API_URL=http://localhost:5799
VITE_IMAGES_URL=http://localhost:5799/images

# ── Produção (Vercel + Supabase) ────────────────────────────────────────────
# Configure estas variáveis no painel da Vercel (não no código)

# Frontend — baked na build pelo Vite
VITE_API_URL=/api
VITE_IMAGES_URL=https://SEU_PROJETO.supabase.co/storage/v1/object/public/images

# Backend — lidas apenas pelas Vercel Functions (não ficam no bundle do frontend)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
